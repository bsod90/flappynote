{
  "name": "flappynote",
  "version": "1.0.0",
  "description": "Free in-browser music practice tools: Vocal Monitor for pitch visualization, a Metronome with mic listen-back, and an interactive color-coded Circle of Fifths.",
  "homepage": "https://flappynote.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/bsod90/flappynote.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:pitch-engine": "vitest run src/pitch-engine",
    "test:browser": "playwright test"
  },
  "keywords": [
    "music",
    "pitch",
    "vocal",
    "training",
    "education",
    "metronome",
    "tempo",
    "tap-tempo",
    "listen-back",
    "onset-detection",
    "practice-session",
    "vocal-training",
    "circle-of-fifths",
    "music-theory",
    "ear-training",
    "key-signatures",
    "diatonic-chords"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.20",
    "jsdom": "^27.0.0",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "vite": "^7.1.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.11.0",
    "pitchfinder": "^2.3.2",
    "pitchy": "^4.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "tailwind-merge": "^3.5.0"
