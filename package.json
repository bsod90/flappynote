{
  "name": "flappynote",
  "version": "1.0.0",
  "description": "Free in-browser music practice tools: Vocal Monitor for pitch visualization, a Metronome with mic listen-back, an interactive color-coded Circle of Fifths, and a chromatic Tuner for guitar, bass, ukulele, and violin.",
  "homepage": "https://flappynote.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/bsod90/flappynote.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:pitch-engine": "vitest run src/pitch-engine",
    "test:browser": "playwright test"
  },
  "keywords": [
    "music",
    "pitch",
    "vocal",
    "training",
    "education",
    "metronome",
    "tempo",
    "tap-tempo",
    "listen-back",
    "onset-detection",
    "practice-session",
    "vocal-training",
    "circle-of-fifths",
    "music-theory",
    "ear-training",
    "key-signatures",
    "diatonic-chords",
    "tuner",
    "guitar-tuner",
    "bass-tuner",
    "ukulele-tuner",
    "violin-tuner",
    "chromatic-tuner",
    "instrument-tuner"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "pitchfinder": "^2.3.4",
    "pitchy": "^4.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "tailwind-merge": "^3.6.0"
  }
}
